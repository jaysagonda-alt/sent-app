generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String  @id @default(cuid())
  email        String  @unique
  name         String
  password     String
  bio          String?
  profileImage String?

  // Mission info
  missionOrg   String?
  denomination String?
  missionType  String? // e.g., "campus", "church-planting", "rescue-ministry"
  location     String?
  country      String?

  // Faith/Values
  denominationPreference String[]
  missionTypePreference  String[]
  languagesSpoken        String[]

  // Timestamps
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  lastSeen  DateTime?

  // Relations
  posts            Post[]
  sentMessages     Message[]     @relation("from")
  receivedMessages Message[]     @relation("to")
  sentRequests     Connection[]  @relation("from")
  receivedRequests Connection[]  @relation("to")
  blockedUsers     BlockedUser[] @relation("blocker")
  blockedBy        BlockedUser[] @relation("blocked")

  @@index([email])
  @@index([missionOrg])
  @@index([createdAt])
}

model Post {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Post content
  type         String // "scripture", "vision", "prayer", "status"
  title        String?
  content      String
  scriptureRef String? // e.g., "John 3:16"

  // Engagement
  likes    Int       @default(0)
  comments Comment[]

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([createdAt])
  @@index([type])
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  content   String
  createdAt DateTime @default(now())

  @@index([postId])
  @@index([userId])
}

model Message {
  id     String @id @default(cuid())
  fromId String
  from   User   @relation("from", fields: [fromId], references: [id], onDelete: Cascade)
  toId   String
  to     User   @relation("to", fields: [toId], references: [id], onDelete: Cascade)

  content   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([fromId])
  @@index([toId])
  @@index([createdAt])
}

model Connection {
  id     String @id @default(cuid())
  fromId String
  from   User   @relation("from", fields: [fromId], references: [id], onDelete: Cascade)
  toId   String
  to     User   @relation("to", fields: [toId], references: [id], onDelete: Cascade)

  status    String   @default("pending") // "pending", "connected", "rejected"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([fromId, toId])
  @@index([status])
}

model BlockedUser {
  id        String   @id @default(cuid())
  blockerId String
  blocker   User     @relation("blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blockedId String
  blocked   User     @relation("blocked", fields: [blockedId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([blockerId, blockedId])
}

model EmailVerification {
  id        String   @id @default(cuid())
  email     String   @unique
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model ConversationStarter {
  id        String   @id @default(cuid())
  content   String
  category  String // "faith", "mission", "values", "interests"
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}
